<view><custom vue-id="1" bind:__l="__l" vue-slots="{{['default']}}">报销申请明细</custom><block wx:if="{{numList.length>0}}"><view class="cu-bar bg-white solid-bottom margin-top"><view class="action"><text class="icon-title text-orange"></text>流程步骤</view></view></block><block wx:if="{{numList.length>0}}"><view class="bg-white padding"><view class="cu-steps"><block wx:for="{{numList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['cu-item',item.Code==='First'||item.Code==='Finish'&&entitys[0].Closed==='Yes'&&entitys[0].DocStatus==='Close'?'text-blue':stepColor[item.ApproveStatus]]}}"><text class="{{['num',item.ApproveStatus===2?'err':'']}}" data-target="Modal" data-index="{{index+1}}" data-event-opts="{{[['tap',[['showStepInfo',['$0','$event'],[[['numList','',index]]]]]]]}}" bindtap="__e"></text>{{''+item.Name+''}}</view></block></view></view></block><view class="{{['cu-modal',modalName=='Modal'?'show':'']}}"><view class="cu-dialog"><view class="cu-bar bg-white justify-end"><view class="content"><view>审核信息</view></view><view data-event-opts="{{[['tap',[['hideModal',['$event']]]]]}}" class="action" bindtap="__e"><text class="icon-roundclose text-black"></text></view></view><view><view class="cu-form-group" readonly><view class="title">时间</view><text class="text-orange">{{showcontent.date}}</text></view><view class="cu-form-group" readonly><view class="title">审核人</view><text class="text-orange">{{showcontent.name}}</text></view><view class="cu-form-group" readonly><view class="title">意见</view><text class="text-orange">{{showcontent.content}}</text></view></view></view></view><block wx:for="{{entitys}}" wx:for-item="item" wx:for-index="index1" wx:key="index1"><block wx:if="{{entitys.length>0}}"><view class="{{['cu-card dynamic margin-top',isCard?'no-card':'']}}"><view class="cu-item shadow"><view style="position:relative;"><view class="content padding-tb-sm"><view><text class="icon-list text-blue margin-right-xs"></text>{{item.ExpendTypeName+"/"+item.Amount+"  开票公司:"+item.InvCompanyName}}</view><view class="text-gray text-sm"><text class="icon-timefill margin-right-xs"></text>{{''+item.PayType+"  "+item.AccountNumber+"  "+item.AcceptingUnit}}</view><view class="text-gray text-sm"><text class="icon-coin margin-right-xs"></text>{{"备注："+item.Remarks}}</view></view></view><view class="text-gray text-sm text-right padding"><view class="cu-capsule round"><view class="cu-tag bg-cyan ">总金额</view><view class="cu-tag line-cyan">{{''+item.Amount+''}}</view></view></view></view></view></block></block></view>