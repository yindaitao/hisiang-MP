<view><custom vue-id="1" bgColor="bg-gradual-pink" bind:__l="__l" vue-slots="{{['default']}}">费用报销明细</custom><block wx:if="{{numList.length>0}}"><view class="cu-bar bg-white solid-bottom margin-top"><view class="action"><text class="icon-title text-orange"></text>流程步骤</view></view></block><block wx:if="{{numList.length>0}}"><view class="bg-white padding"><view class="cu-steps"><block wx:for="{{numList}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="{{['cu-item',item.Code==='First'||item.Code==='Finish'&&entitys[0].Closed==='Yes'&&entitys[0].DocStatus==='Close'?'text-blue':stepColor[item.ApproveStatus]]}}"><text class="{{['num',item.ApproveStatus===2?'err':'']}}" data-target="Modal" data-index="{{index+1}}" data-event-opts="{{[['tap',[['showStepInfo',['$0','$event'],[[['numList','',index]]]]]]]}}" bindtap="__e"></text>{{''+item.Name+''}}</view></block></view></view></block><view class="{{['cu-modal',modalName=='Modal'?'show':'']}}"><view class="cu-dialog"><view class="cu-bar bg-white justify-end"><view class="content"><view>审核信息</view></view><view data-event-opts="{{[['tap',[['hideModal',['$event']]]]]}}" class="action" bindtap="__e"><text class="icon-roundclose text-black"></text></view></view><view><view class="cu-form-group" readonly><view class="title">时间</view><text class="text-orange">{{showcontent.date}}</text></view><view class="cu-form-group" readonly><view class="title">审核人</view><text class="text-orange">{{showcontent.name}}</text></view><view class="cu-form-group" readonly><view class="title">意见</view><text class="text-orange">{{showcontent.content}}</text></view></view></view></view><view class="cu-bar bg-white solid-bottom margin-top"><view class="action"><text class="icon-title text-orange"></text>报销明细</view><view class="action">总金额：<block wx:if="{{entitys.length>0}}"><view class="cu-tag round bg-olive light">{{entitys[0].Amount}}</view></block></view></view><view class="{{['cu-card dynamic',isCard?'no-card':'']}}"><view class="cu-item shadow"><view style="position:relative;"><view class="content">{{entitys[0].CompanyName+" / "+entitys[0].OrganizationName+" / "+entitys[0].Creator}}</view><view class="content">{{"单据编号:"+entitys[0].DocEntry+"  RMB:"+entitys[0].Amount}}</view><view class="content">{{"开票公司:"+entitys[0].InvCompanyName}}</view><view class="content">{{"支付方式:"+entitys[0].PayType+"  账号(卡号):"+entitys[0].AccountNumber+"  受理单位(银行):"+entitys[0].AcceptingUnit}}</view><view class="content"><view class="text-gray text-sm"><view class="_h4">{{"备注："+entitys[0].Remarks}}</view></view></view></view></view></view><block wx:for="{{entitys[0].ReimbursementRequestLines}}" wx:for-item="item" wx:for-index="index1" wx:key="index1"><block wx:if="{{entitys.length>0}}"><view class="{{['cu-card dynamic padding-sm',isCard?'no-card':'']}}"><view class="cu-item shadow"><view style="position:relative;"><view class="cu-tag bg-gray" style="position:absolute;top:10px;right:10px;">{{"费用报销明细("+NumArray[index1]+")  RMB:"+item.Amount}}</view><view class="content padding-tb-sm"><view><text class="icon-list text-blue margin-right-xs"></text>{{item.ReimbursementTypeName+" 报销"}}</view><view class="text-gray text-sm"><text class="icon-timefill margin-right-xs"></text>{{''+item.DocDate}}</view><view class="text-gray text-sm"><text class="icon-coin margin-right-xs"></text>{{"备注："+item.Remarks}}</view></view></view><block wx:if="{{item.pathArr.length>0}}"><view class="{{['grid flex-sub padding-lr',isCard?'col-3 grid-square':'col-1']}}"><block wx:for="{{item.pathArr}}" wx:for-item="_item" wx:for-index="index" wx:key="index"><view class="{{['bg-img',isCard?'':'only-img']}}" style="{{'background-image:'+('url('+_item+')')+';'}}"></view></block></view></block></view></view></block></block></view>