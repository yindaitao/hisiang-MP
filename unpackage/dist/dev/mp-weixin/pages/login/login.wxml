<view class="s-page-wrapper is-100vh"><view class="is-33vh"><view class="is-flex is-column is-justify-center is-align-center is-height-100"><image class="logoimg" style="top:100px;" src="{{loginImg}}" mode="aspectFit"></image></view></view><view class="content"><view class="has-mglr-10"><view class=" has-mgtb-10"><input class="is-input1" type="text" placeholder="请输入账号" data-val="userCode" data-event-opts="{{[['input',[['__set_model',['$0','userCode','$event',[]],['logininfo']]]]]}}" value="{{logininfo.userCode}}" bindinput="__e"/></view><view class=" has-radius has-mgtb-10"><input class="is-input1" placeholder="请输入登录密码" password data-val="password" data-event-opts="{{[['confirm',[['handleLogin',['$event']]]],['input',[['__set_model',['$0','password','$event',[]],['logininfo']]]]]}}" value="{{logininfo.password}}" bindconfirm="__e" bindinput="__e"/></view><view class=" loginbtn has-radius has-mgtb-20"><button open-type="getUserInfo" disabled="{{logininfo.loading}}" data-event-opts="{{[['tap',[['defaultHandlerLogin',['$event']]]]]}}" bindtap="__e">{{''+(logininfo.loading?"登录中...":"登 录")+''}}</button></view></view></view></view>