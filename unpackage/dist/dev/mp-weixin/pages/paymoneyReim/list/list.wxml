<view class="ul-uni-tab-bar"><custom vue-id="1" bind:__l="__l" vue-slots="{{['default']}}">还款申请列表</custom><block wx:if="{{!isMultiSelect}}"><view class="cu-bar search bg-white vue-ref" id="_tabBar" data-ref="_tabBar"><view class="search-form round"><text class="icon-search"></text><input adjust-position="{{false}}" type="text" placeholder="输入搜索关键词" confirm-type="search" data-event-opts="{{[['focus',[['InputFocus',['$event']]]],['blur',[['InputBlur',['$event']]]],['input',[['searchInput',['$event']]]]]}}" value="{{searchValue}}" bindfocus="__e" bindblur="__e" bindinput="__e"/></view><view class="action"><button data-event-opts="{{[['tap',[['doSearch',['$event']]]]]}}" class="cu-btn icon" bindtap="__e"><text class="icon-search"></text></button></view><view class="action"><button data-event-opts="{{[['tap',[['addWorkOrder',['$event']]]]]}}" class="cu-btn icon" bindtap="__e"><text class="icon-roundadd"></text></button></view></view></block><view class="ul-swiper-box" style="margin-top:2rpx;"><scroll-view style="{{'width:100%;margin-bottom:10px;'+('height:'+(scrollBarHeight+'px')+';')}}" scroll-y data-event-opts="{{[['scrolltolower',[['loadMore']]]]}}" bindscrolltolower="__e"><view class="cu-list menu"><block wx:for="{{dataList}}" wx:for-item="list" wx:for-index="index" wx:key="index"><view class="{{['cu-item',modalName=='move-box-'+index?'move-cur':'']}}" style="position:relative;" data-target="{{'move-box-'+index}}" data-event-opts="{{[['touchstart',[['ListTouchStart',[index,'$event']]]],['touchmove',[['ListTouchMove',[index,'$event']]]],['touchend',[['ListTouchEnd',[index,'$event']]]],['tap',[['goDetail',['$0'],[[['dataList','',index]]]]]]]}}" bindtouchstart="__e" bindtouchmove="__e" bindtouchend="__e" bindtap="__e"><block wx:if="{{list.Approve==='No'&&list.ApproveStatus!=='Rejected'}}"><view class="cu-tag bg-blue" style="position:absolute;top:10px;right:10px;">草稿</view></block><block wx:if="{{isMultiSelect}}"><view style="height:100%;text-align:center;vertical-align:middle;margin-top:30px;"><radio checked="{{list.radchecked}}" data-event-opts="{{[['tap',[['radioClick',['$0'],[[['dataList','',index]]]]]]]}}" catchtap="__e"></radio></view></block><view class="content padding-tb-sm"><view><text class="icon-peoplefill text-blue margin-right-xs"></text>{{''+list.OrganizationName+"-"+list.Creator+'的还款申请'}}</view><view><text class="icon-title text-orange"></text>{{'还款金额:'+list.Amount+''}}</view><view class="text-gray text-sm"><text class="icon-timefill margin-right-xs"></text>{{''+list.CreateDate+''}}</view><view class="text-gray text-sm"></view></view><block wx:if="{{list.Approve!=='No'||list.ApproveStatus==='Rejected'}}"><view class="action"><block wx:if="{{list.ApproveStatus==='Pending'}}"><view class="cu-tag round bg-olive light">{{list.AApproveStatus}}</view></block><block wx:if="{{list.ApproveStatus==='Approved'}}"><view class="cu-tag round bg-blue light">{{list.AApproveStatus}}</view></block><block wx:if="{{list.ApproveStatus==='Rejected'}}"><view class="cu-tag round bg-red light">{{list.AApproveStatus}}</view></block></view></block><block wx:if="{{list.Approve==='No'||list.ApproveStatus==='Rejected'}}"><view class="move"><view data-event-opts="{{[['tap',[['editItem',['$0'],[[['dataList','',index]]]]]]]}}" class="bg-grey" catchtap="__e">编辑</view><view data-event-opts="{{[['tap',[['deleteItem',['$0'],[[['dataList','',index]]]]]]]}}" class="bg-red" catchtap="__e">删除</view></view></block></view></block></view></scroll-view></view></view>